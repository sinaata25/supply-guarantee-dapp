{"nodes": [{"id": "readme_supplyguarantee_dapp", "label": "SupplyGuarantee dApp", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces paper-heavy, bank-intermediated trade workflows (letters of credit) with transparent programmable escrow: buyers fear paying upfront, sellers fear non-payment, banks charge high intermediary fees, and off-chain documents are unverifiable."}, {"id": "readme_supplyguarantee_contract", "label": "SupplyGuarantee.sol Escrow Contract", "file_type": "code", "source_file": "README.md", "source_location": "contracts/SupplyGuarantee.sol", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Entirely self-contained with no OpenZeppelin dependencies; implements its own SafeERC20Lite, OwnableLite, PausableLite, ReentrancyGuardLite to minimize attack surface and external dependencies."}, {"id": "readme_mockusd_contract", "label": "MockUSD ERC-20 Test Token", "file_type": "code", "source_file": "README.md", "source_location": "contracts/MockUSD.sol", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_order_lifecycle", "label": "Order Lifecycle Finite-State Machine", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Strict FSM (Created -> Funded -> AdvanceRequested -> AdvanceApproved -> AdvancePaid -> InMilestones -> Finalized, with Disputed/Cancelled branches); each transition emits OrderStageChanged so the indexer can mirror state."}, {"id": "readme_milestone_lifecycle", "label": "Milestone Lifecycle", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each milestone independently tracks NotStarted -> Planned -> PlanApproved -> Delivered -> InspectionApproved -> BuyerApproved -> Paid; when all reach Paid the order auto-finalizes, enabling milestone-by-milestone fund release."}, {"id": "readme_roles_access_control", "label": "Roles and Access Control", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Six per-order roles (buyer, seller, carrier, inspector, bank, arbiter) plus owner; every function gated by a specific role modifier with no general-admin bypass; onlyConfigurator (owner OR buyer OR seller) governs order setup."}, {"id": "readme_document_anchoring", "label": "Document Anchoring (DocSlot)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every trade document is anchored on-chain as a bytes32 SHA-256 hash in a DocSlot struct (hash32, timestamp, submitter), creating an immutable audit trail; each submission emits DocSubmitted."}, {"id": "readme_milestone_bps_system", "label": "Milestone BPS (Basis Points) System", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Contract enforces advanceBps + sum(milestone.bps) == 10000 before lock, guaranteeing 100% of the purchase price is always accounted for; milestone amount = price * bps / 10000 at lock time."}, {"id": "readme_security_patterns", "label": "Security Patterns (Lite Implementations)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom ReentrancyGuardLite on fund/bankPayAdvance/bankPayMilestone/_refund, SafeERC20Lite low-level call wrapper, PausableLite emergency halt, role modifiers, optional deadlines, SIWE nonce rotation for replay prevention."}, {"id": "readme_siwe_authentication", "label": "SIWE Authentication Flow (EIP-4361)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Wallet-signature login instead of passwords: nonce expires in 5 minutes, nonce rotated immediately after verification to prevent replay, backend independently rebuilds the SIWE message rather than trusting frontend text, addresses stored checksummed."}, {"id": "readme_nextjs_frontend", "label": "Next.js 16 / React 19 Frontend", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_django_backend", "label": "Django REST Backend (DRF + SimpleJWT)", "file_type": "concept", "source_file": "README.md", "source_location": "backend/centralize", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_subgraph_indexer", "label": "The Graph Subgraph Indexer", "file_type": "concept", "source_file": "README.md", "source_location": "supp/", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_web3provider", "label": "Web3Provider Global Wallet/Auth Context", "file_type": "code", "source_file": "README.md", "source_location": "components/web3/Web3Provider.jsx", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_auth_nonce_endpoint", "label": "POST /auth/nonce/ Endpoint", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_auth_verify_endpoint", "label": "POST /auth/verify/ Endpoint", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_