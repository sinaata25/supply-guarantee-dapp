# Copy this file to .env (same folder) and fill in your own values.
# NEVER commit the real .env — it is gitignored.

# Private key of the wallet that deploys (needs Sepolia ETH).
# MetaMask: account menu -> Account details -> Show private key.
DEPLOYER_PRIVATE_KEY=0xyour_private_key_here

# Optional: your own RPC (Alchemy/Infura). Defaults to a public Sepolia RPC.
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<key>
